# ─── Server ───────────────────────────────────────────
PORT=3001

# ─── Firebase (Required for real DB sync) ─────────────
# Get from: Firebase Console → Project Settings → General
FIREBASE_DB_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com

# Firebase Admin auth (pick ONE):
# Option A: Set this to the path of your downloaded service account JSON
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json
# Option B: Uncomment the require() line in server/index.js

# ─── Twilio WhatsApp (Optional) ───────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Numbers that receive fire/gas alerts (JSON array)
# Each number must have joined the Twilio WhatsApp sandbox first
ALERT_NUMBERS=["+91XXXXXXXXXX","+91YYYYYYYYYY"]

# ─── Arduino Thresholds (must match Arduino constants) ─
# FIRE_THRESHOLD: MQ-2 ADC value above which fire alert triggers
FIRE_THRESHOLD=400
# TANK_EMPTY_CM: Ultrasonic distance (cm) at which pump turns ON
TANK_EMPTY_CM=20
# TANK_FULL_CM:  Ultrasonic distance (cm) at which pump turns OFF
TANK_FULL_CM=5
